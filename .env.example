# Canvas LMS API token
# Generate at: Canvas > Account > Settings > Approved Integrations > New Access Token
CANVAS_API_TOKEN=your_token_here

# Base URL of your Canvas instance (no trailing slash)
CANVAS_BASE_URL=https://canvas.uw.edu

# Directory for Google OAuth credentials (client_secret.json, token.json)
# Default: ./credentials
CREDENTIALS_DIR=./credentials
